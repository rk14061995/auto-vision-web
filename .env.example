# Public URL of this app (used in emails, referral links, og:url)
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# Dashboard app URL (auto-vision-dashboard)
NEXT_PUBLIC_DASHBOARD_URL=http://localhost:3001

# NextAuth secret — generate with: openssl rand -base64 32
AUTH_SECRET=your-auth-secret-here

# Comma-separated list of emails with admin access to /admin
ADMIN_EMAILS=you@example.com

# Razorpay (India payments) — https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret

# Paddle (international payments) — https://vendors.paddle.com/authentication
# Client token: Paddle dashboard → Developer Tools → Authentication
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=your-paddle-client-token
PADDLE_API_KEY=your-paddle-api-key
PADDLE_WEBHOOK_SECRET=your-paddle-webhook-secret
# Price IDs: Paddle dashboard → Catalog → Prices
PADDLE_PRICE_CREATOR=pri_xxxxxxxxxxxxxxxxxx
PADDLE_PRICE_PRO=pri_xxxxxxxxxxxxxxxxxx
PADDLE_PRICE_STUDIO=pri_xxxxxxxxxxxxxxxxxx

# LemonSqueezy — DISABLED (replaced by Paddle, kept for future re-enable)
# LEMONSQUEEZY_API_KEY=your-lemonsqueezy-api-key
# NEXT_PUBLIC_LEMONSQUEEZY_STORE_ID=your-store-slug
# LS_VARIANT_CREATOR=1595234
# LS_VARIANT_PRO=lspro_placeholder
# LS_VARIANT_STUDIO=1595261

# MongoDB Atlas — https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/

# Cloudinary — https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name

# Google Analytics 4 Measurement ID (format: G-XXXXXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# AI Features — https://console.anthropic.com/keys
# Powers: Claude Vision car part detection (detect-parts) + AI color theme generator (color-theme)
ANTHROPIC_API_KEY=sk-ant-...

# Background removal — https://www.remove.bg/api
# Powers: real background removal (remove-background). Leave blank to fall back to local algorithm.
REMOVE_BG_API_KEY=your-remove-bg-api-key
